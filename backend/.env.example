# Template for backend env vars. Copy this to `.env` and fill in real values.
# This file IS committed to git so others know which variables are needed.

# ─── LLM provider ─────────────────────────────────────────────────
# Options: "bedrock" (primary), "ollama" (free local), "anthropic" (legacy).
LLM_PROVIDER=bedrock

# ─── AWS Bedrock ──────────────────────────────────────────────────
# IAM access keys for an AWS user with AmazonBedrockFullAccess policy.
# Create at: AWS Console → IAM → Users → <user> → Security credentials.
AWS_ACCESS_KEY_ID=AKIA-your-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
AWS_REGION=us-east-1

# Bedrock model IDs — copy exact strings from the Bedrock Model catalog.
# Sonnet for synthesis (quality), Haiku for extraction (cheap).
# Newer Claude models (4.x) require the "us." cross-region inference profile
# prefix — plain model IDs hit "on-demand throughput isn't supported" errors.
BEDROCK_MODEL_ID_SYNTHESIS=us.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_ID_FAST=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ─── LangSmith tracing ────────────────────────────────────────────
# Get an API key at https://smith.langchain.com/.
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_key_here
LANGSMITH_PROJECT=equity-research-copilot

# ─── Legacy direct-Anthropic key (optional) ───────────────────────
# Only used if LLM_PROVIDER=anthropic. Get at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────────
# Frontend origin(s) allowed to call the backend (JSON array).
CORS_ORIGINS=["http://localhost:5173"]

# ─── Phase 1: Embeddings ──────────────────────────────────────────
# Provider: "voyage" (finance-tuned, preferred) or "openai" (fallback).
EMBEDDING_PROVIDER=voyage

# Voyage AI — https://www.voyageai.com/ (50M free tokens for voyage-finance-2).
# Free signup, no credit card required.
VOYAGE_API_KEY=pa-your-voyage-key-here
VOYAGE_EMBEDDING_MODEL=voyage-finance-2

# ─── Phase 1: SEC EDGAR ───────────────────────────────────────────
# SEC requires a User-Agent in the literal format "Name email@example.com".
# Requests without it (or with junk values) are 403'd / rate-limited.
EDGAR_USER_AGENT=Your Name your.email@example.com

# ─── Phase 1: Chunker ─────────────────────────────────────────────
# Section-aware chunking for filings prose. Tunable later via eval data.
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ─── Phase 1: Chroma vector store ─────────────────────────────────
# Where Chroma persists its SQLite + vector index. Path is relative
# to backend/. Add chroma_db/ to .gitignore (don't commit embeddings).
CHROMA_PERSIST_DIR=./chroma_db
