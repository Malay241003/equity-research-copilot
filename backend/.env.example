# Template for backend env vars. Copy this to `.env` and fill in real values.
# This file IS committed to git so others know which variables are needed.

# ─── LLM ──────────────────────────────────────────────────
# Provider to use. Options: "anthropic" or "ollama".
LLM_PROVIDER=anthropic

# Anthropic API key. Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=your-anthropic-key-here

# ─── CORS ─────────────────────────────────────────────────
# Frontend origin(s) allowed to call the backend (JSON array, comma-separated).
CORS_ORIGINS=["http://localhost:5173"]
